 # AC_CONFIG_SUBDIRS will be traversed in &autoreconf_current_directory.
+$ENV{'AUTOCONF'} = $C{autoconf};
 $ENV{'AUTOM4TE'} = $C{autom4te};
 for my $directory (@ARGV)
   {
