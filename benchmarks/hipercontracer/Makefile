SYNC_CMAKE_BOOL=		WITH_SYNC

TRIGGER_IMPLIES=		LIBHIPERCONTRACER
TRIGGER_CMAKE_BOOL=		WITH_TRIGGER

UDPECHO_CMAKE_BOOL=		WITH_UDP_ECHO_SERVER

VIEWER_USES=			desktop-file-utils
VIEWER_CMAKE_BOOL=		WITH_VIEWER

