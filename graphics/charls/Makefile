		CHARLS_BUILD_SAMPLES \
		CHARLS_INSTALL
CMAKE_TESTING_ON=	\
		CHARLS_BUILD_FUZZ_TEST \
		CHARLS_BUILD_TESTS
USE_LDCONFIG=	yes

PLIST_SUB=	PORTVERSION=${PORTVERSION}

