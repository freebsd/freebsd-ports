--- ext/qm-dsp/meson.build.orig	2024-11-21 11:39:58 UTC
+++ ext/qm-dsp/meson.build
@@ -8,15 +8,11 @@ qm_dsp_lib_c_args = [
   '-Dkiss_fft_scalar=double',
   '-Wall',
   '-Wextra',
-  '-O3',
   '-ftree-vectorize',
   '-DUSE_PTHREADS',
   ]
 if host_machine.cpu() == 'x86_64'
   qm_dsp_lib_c_args += [
-    '-msse',
-    '-msse2',
-    '-mfpmath=sse',
     ]
 endif
 
