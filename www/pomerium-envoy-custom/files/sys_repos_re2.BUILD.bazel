load("@rules_cc//cc:defs.bzl", "cc_library")

cc_import(
    name = "_re2",
    shared_library = "libre2.so",
)

cc_library(
    name = "re2",
    hdrs = glob(["re2/*.h"]),
    includes = [""],
    deps = [":_re2"],
    visibility = ["//visibility:public"],
)

filegroup(
    name = "all",
    srcs = glob(["re2/*.h"]) + ["libre2.so"],
    visibility = ["//visibility:public"],
)
