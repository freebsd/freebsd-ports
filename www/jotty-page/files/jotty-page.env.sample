# /usr/local/etc/jotty-page.env
#
# Environment configuration for jotty-page.
# Copy this file to /usr/local/etc/jotty-page.env and edit as needed.
# Lines starting with # are comments and are ignored.
# The rc script exports each KEY=value line into the daemon environment.
#
# Restart the service after any change:
#   service jotty_page restart

# ---------------------------------------------------------------------------
# Mandatory for production
# ---------------------------------------------------------------------------

# Node.js environment (do not change for production deployments).
NODE_ENV=production

# ---------------------------------------------------------------------------
# Networking
# ---------------------------------------------------------------------------

# TCP port the application listens on.  Defaults to 3000 if not set here;
# override in rc.conf via jotty_page_port instead when possible.
#PORT=3000

# Bind address.  Set to 0.0.0.0 to listen on all interfaces.
#HOSTNAME=127.0.0.1

# ---------------------------------------------------------------------------
# Application URL  (required for SSO / OIDC)
# ---------------------------------------------------------------------------

# Public base URL of this instance.  Must match the URL users open in their
# browser.  Required for OIDC redirects; also helps with reverse-proxy setups.
#APP_URL=https://jotty.example.com

# Internal URL used for server-side API calls.  Only needed when the public
# URL is not reachable from the host itself (e.g. behind a reverse proxy with
# strict host matching).
#INTERNAL_API_URL=http://localhost:3000

# ---------------------------------------------------------------------------
# Authentication
# ---------------------------------------------------------------------------

# Authentication mode.  Supported values: "local" (default), "oidc".
#AUTH_MODE=local

# Allow local accounts even when OIDC is the primary auth mode.
#SSO_FALLBACK_LOCAL=yes

# ---------------------------------------------------------------------------
# OIDC / SSO  (required when AUTH_MODE=oidc)
# ---------------------------------------------------------------------------

#OIDC_ISSUER=https://auth.example.com/realms/master
#OIDC_CLIENT_ID=jotty-page
#OIDC_CLIENT_SECRET=your_client_secret

# Path to a file containing the client ID / secret (takes priority over the
# plain variables above; useful with FreeBSD jails or secrets managers).
#OIDC_CLIENT_ID_FILE=/var/db/jotty-page/secrets/oidc_client_id
#OIDC_CLIENT_SECRET_FILE=/var/db/jotty-page/secrets/oidc_client_secret

# OIDC groups/roles that receive administrator privileges.
#OIDC_ADMIN_GROUPS=admins
#OIDC_ADMIN_ROLES=admin

# OIDC groups/roles allowed to log in (if unset, all authenticated users can
# log in).
#OIDC_USER_GROUPS=jotty_users
#OIDC_USER_ROLES=user

# Scope used to retrieve group membership.  Set to empty or "no" for
# providers (e.g. Entra ID) that do not support a "groups" scope.
#OIDC_GROUPS_SCOPE=groups

# Custom logout redirect URL (for global SSO logout).
#OIDC_LOGOUT_URL=https://auth.example.com/realms/master/logout

# ---------------------------------------------------------------------------
# TLS / HTTPS
# ---------------------------------------------------------------------------

# Enable HTTPS mode.  When set, the application expects to be reached over
# HTTPS; use a reverse proxy (e.g. nginx, Caddy, haproxy) for TLS termination.
#HTTPS=true

# ---------------------------------------------------------------------------
# File serving
# ---------------------------------------------------------------------------

# Allow unauthenticated access to uploaded images / files / videos via their
# direct URLs.
#SERVE_PUBLIC_IMAGES=yes
#SERVE_PUBLIC_FILES=yes
#SERVE_PUBLIC_VIDEOS=yes

# ---------------------------------------------------------------------------
# Upload size limit
# ---------------------------------------------------------------------------

# Maximum request body size for Server Actions (file uploads, avatars, …).
# Accepts <number><unit> where unit is b, kb, mb or gb (e.g. "200mb").
# NOTE: changing this value requires reinstalling the port so that the
#       body-size runtime patch is re-applied with the new limit.
#JOTTY_BODY_SIZE_LIMIT=100mb

# ---------------------------------------------------------------------------
# Miscellaneous
# ---------------------------------------------------------------------------

# Default locale shown on the login page (e.g. "en", "de", "fr").
#DEFAULT_LOCALE=en

# Disable the GitHub update-check toast notification.
#STOP_CHECK_UPDATES=yes

# Disable brute-force login protection (NOT recommended for public instances).
#DISABLE_BRUTEFORCE_PROTECTION=yes

# Enable pinch-to-zoom in PWA mode (accessibility).
#ENABLE_PWA_ZOOM=yes

# Debug flags: "proxy", "crud", or "*" for everything.
#DEBUGGER=

# ---------------------------------------------------------------------------
# FreeBSD-specific  (set by the port; do not change)
# ---------------------------------------------------------------------------
JOTTY_FREEBSD=1
