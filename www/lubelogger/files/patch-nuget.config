--- nuget.config.orig	2026-04-19 09:21:52 UTC
+++ nuget.config
@@ -0,0 +1,9 @@
+<?xml version="1.0" encoding="utf-8"?>
+<configuration>
+  <packageSources>
+    <!--To inherit the global NuGet package sources remove the clear line below -->
+    <clear />
+    <add key="a" value="%%LOCALBASE%%/share/dotnet/packs" />
+    <add key="b" value="%%NUGET_DISTDIR%%" />
+  </packageSources>
+</configuration>
