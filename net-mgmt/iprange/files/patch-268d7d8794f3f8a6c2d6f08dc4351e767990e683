 src/ipset6_load.c     |  12 +--
 src/ipset6_optimize.c |  16 +--
 src/ipset6_print.c    |  22 ++--
 src/uint128.h         | 230 ++++++++++++++++++++++++++++++++++++++++++
 15 files changed, 356 insertions(+), 121 deletions(-)
 create mode 100644 src/uint128.h

