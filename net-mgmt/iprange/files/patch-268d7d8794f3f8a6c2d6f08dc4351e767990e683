 configure.ac          |   5 +-
 src/iprange6.h        |  53 +++++-----
 src/iprange6_main.c   |  24 ++---
 src/ipset6.c          |   4 +-
 src/ipset6.h          |  20 ++--
 src/ipset6_binary.c   |  36 +++----
 src/ipset6_common.c   |   8 +-
