-        return addr | ((__uint128_t)1 << (128 - bitno));
+        return u128_or(addr, u128_shl(U128_ONE, 128 - bitno));
     else
-        return addr & ~((__uint128_t)1 << (128 - bitno));
+        return u128_and(addr, u128_not(u128_shl(U128_ONE, 128 - bitno)));
