upstreams:
  groups:
    default:
      - 8.8.8.8
      - 1.1.1.1
      - https://dns.digitale-gesellschaft.ch/dns-query

queryLog:
  type: none

blocking:
  denylists:
    ads:
      - https://raw.githubusercontent.com/StevenBlack/hosts/master/hosts
  clientGroupsBlock:
    default:
      - ads

ports:
  dns: 53
  http: 4000
