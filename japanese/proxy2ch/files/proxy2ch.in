#!/bin/sh

# PROVIDE: proxy2ch
# REQUIRE: LOGIN
# KEYWORD: shutdown

# proxy2ch_args (string):	Extra arguments passed to proxy2ch
#				Default is "-c"

. /etc/rc.subr

name=proxy2ch
rcvar=${name}_enable

load_rc_config ${name}
: ${proxy2ch_enable:=NO}
: ${proxy2ch_svcj_options:="net_basic"}
: ${proxy2ch_args:="-c"}

pidfile=/var/run/${name}.pid
command="/usr/sbin/daemon"
command_args="-frP ${pidfile} %%PREFIX%%/sbin/${name} ${proxy2ch_args}"

run_rc_command "$1"
