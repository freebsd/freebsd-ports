--- bindings/Makefile.in.orig	2026-05-19 19:34:45 UTC
+++ bindings/Makefile.in
@@ -728,11 +728,11 @@ install-data-local:
 install-data-local:
 	$(AM_V_GEN)test -f ${builddir}/perl-piped/Makefile \
            && ( cd ${builddir}/perl-piped \
-	        && $(MAKE) install ) \
