+	-$(DLBMANCREATE) ${DESTDIR}$(MANDIR)/dlb.$(MANEXT)
+	-$(MDMANCREATE) ${DESTDIR}$(MANDIR)/makedefs.$(MANEXT)
 
 # manual creation for distribution
 DISTRIB = Guidebook.txt xnethack.txt recover.txt \
