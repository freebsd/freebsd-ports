From 55dd611143184effd54e5f1427500e51b946cff1 Mon Sep 17 00:00:00 2001
From: Nuno Teixeira <eduardo@FreeBSD.org>
Date: Tue, 30 Jun 2026 02:26:01 +0100
Subject: [PATCH] Fix build compilation on FreeBSD / BSD platforms (#1133)

---
 src/DETHRACE/pc-all/allnet.c | 1 +
 src/harness/CMakeLists.txt   | 2 +-
 src/harness/os/linux.c       | 1 +
 3 files changed, 3 insertions(+), 1 deletion(-)

diff --git src/DETHRACE/pc-all/allnet.c src/DETHRACE/pc-all/allnet.c
index fd42b4423..7c3dc46d2 100644
--- src/DETHRACE/pc-all/allnet.c
+++ src/DETHRACE/pc-all/allnet.c
@@ -27,6 +27,7 @@
 
 #include <arpa/inet.h>
 #include <errno.h>
+#include <netinet/in.h>
 #include <sys/socket.h>
 #endif
 
diff --git src/harness/CMakeLists.txt src/harness/CMakeLists.txt
index 259908465..a8ae12e7b 100644
--- src/harness/CMakeLists.txt
+++ src/harness/CMakeLists.txt
@@ -72,7 +72,7 @@ elseif(WIN32)
     target_link_libraries(harness PRIVATE dbghelp ws2_32 iphlpapi)
 elseif(APPLE)
     target_sources(harness PRIVATE os/macos.c)
-elseif(CMAKE_SYSTEM_NAME STREQUAL "Linux")
+elseif(UNIX)
     target_sources(harness PRIVATE os/linux.c)
 else()
     message(FATAL_ERROR "Unsupported or unknown platform: ${CMAKE_SYSTEM_NAME}")
diff --git src/harness/os/linux.c src/harness/os/linux.c
index 295beb09e..4e56374df 100644
--- src/harness/os/linux.c
+++ src/harness/os/linux.c
@@ -32,6 +32,7 @@
 #include <termios.h>
 #include <time.h>
 #include <unistd.h>
+#include <netinet/in.h>
 
 #if SUPPORT_TRACEBACK
 #include <execinfo.h>
