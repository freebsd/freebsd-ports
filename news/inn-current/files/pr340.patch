+            close(fd);
+            nanosleep(&ts, NULL);
+            fd = open(path, O_RDWR | O_CREAT | O_APPEND, 0664);
+            if (fd < 0) {
+                syswarn("can't reopen %s for tombstone append", path);
+                free(path);
+                return false;
+            }
+            if (!inn_lock_file(fd, INN_LOCK_READ, false)) {
+                syswarn("can't lock %s after retry; skipping"
+                        " tombstone entry",
