+        if (bloom_check(OVtokencache, &hash))
+            return true;
+    }
+
+    /* Slow path: per-article history lookup (original behavior).
+     * Only reached for bloom misses or when no bloom filter is loaded. */
     return HISlookup(h, p, NULL, NULL, NULL, NULL);
