+                     reader_dictionary + reader_basedict_len,
+                     "%.*s:%llu\r\n", groupname_len, groupname, artnum);
+    return reader_basedict_len
+           + strlen(reader_dictionary + reader_basedict_len);
+}
+
+#        endif /* USE_DICTIONARY */
+
+#    endif /* HAVE_ZLIB */
