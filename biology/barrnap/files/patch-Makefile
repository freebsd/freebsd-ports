+INSTALL ?= install
+MKDIR_P ?= mkdir -p
+CP ?= cp -R
+
+.PHONY: all install test
+
+all:
+
+install:
+	$(MKDIR_P) $(DESTDIR)$(BINDIR) $(DESTDIR)$(DATADIR)
